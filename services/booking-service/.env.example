# ── Server ────────────────────────────────────────────────────────────────────
PORT=3003
NODE_ENV=development

# ── PostgreSQL (via Sequelize) ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotel_db
DB_USER=hoteluser
DB_PASSWORD=hotelpass

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9092
